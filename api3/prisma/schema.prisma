generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"  
}

datasource db {
  provider = "postgresql"
}


model Drug {
  id             Int        @id @default(autoincrement())
  name           String
  dosage         String
  form           String
  buying_price   Decimal
  selling_price  Decimal
  stock_quantity Int
  expiry_date    DateTime   @db.Date
  
   
  amoDrug        AmoDrug?

  @@map("drugs")
}

model AmoDrug {
  id                 Int   @id @default(autoincrement())
  drug_id            Int   @unique  
  reimbursement_rate Int
  
   
  drug               Drug  @relation(fields: [drug_id], references: [id])

  @@map("amo_drugs")
}

 
model Patient {
  id    Int    @id @default(autoincrement())
  @@map("patients")
}

model Sale {
  id             Int        @id @default(autoincrement())
  patient_id     Int?
  total_amount   Decimal
  payment_method String
  created_at     DateTime   @default(now())
  @@map("sales")
}

model SaleItem {
  id         Int     @id @default(autoincrement())
  sale_id    Int
  drug_id    Int
  quantity   Int
  unit_price Decimal
  @@map("sale_items")
}